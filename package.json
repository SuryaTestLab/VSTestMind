{
  "name": "testmind",
  "displayName": "TestMind — Test Recorder",
  "description": "Record browser interactions and generate Selenium Java test code inside VSCode",
  "version": "1.0.0",
  "publisher": "testmind",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Testing"],
  "keywords": ["selenium", "test recorder", "test automation", "java"],
  "icon": "media/icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testmind.open",
        "title": "TestMind: Open Recorder",
        "icon": "$(beaker)"
      },
      {
        "command": "testmind.launchChrome",
        "title": "TestMind: Launch Chrome"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id":    "testmind",
          "title": "TestMind Recorder",
          "icon":  "media/icon.svg"
        }
      ]
    },
    "views": {
      "testmind": [
        {
          "type": "webview",
          "id":   "testmind.panel",
          "name": "Recorder"
        }
      ]
    },
    "configuration": {
      "title": "TestMind",
      "properties": {
        "testmind.chromePath": {
          "type":        "string",
          "default":     "",
          "description": "Path to Chrome executable. Leave empty for auto-detection."
        },
        "testmind.cdpPort": {
          "type":        "number",
          "default":     9222,
          "description": "Chrome DevTools Protocol debug port."
        },
        "testmind.outputDir": {
          "type":        "string",
          "default":     "src/test/java",
          "description": "Workspace-relative directory where generated .java files are saved."
        },
        "testmind.defaultPackage": {
          "type":        "string",
          "default":     "com.testmind.tests",
          "description": "Default Java package for generated test classes."
        },
        "testmind.defaultFramework": {
          "type":    "string",
          "default": "testng",
          "enum":    ["testng", "junit5", "junit4"],
          "description": "Test framework for generated code."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch":   "tsc -watch -p ./",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.0"
  },
  "devDependencies": {
    "@types/node":   "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript":    "^5.3.0",
    "@vscode/vsce":  "^2.24.0"
  }
}
